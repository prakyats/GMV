rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read and write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Vaults can only be created if the creator is a member
    // and accessed only by existing members
    match /vaults/{vaultId} {
      allow create: if request.auth != null
  && request.resource.data.members.size() == 1
  && request.auth.uid in request.resource.data.members
  && request.resource.data.createdBy == request.auth.uid
  && request.resource.data.name is string;

      allow read, update, delete: if request.auth != null 
        && request.auth.uid in resource.data.members;
    }

    match /memories/{memoryId} {
      allow create: if request.auth != null &&
        get(/databases/$(database)/documents/vaults/$(request.resource.data.vaultId)).data != null &&
        request.auth.uid in
        get(/databases/$(database)/documents/vaults/$(request.resource.data.vaultId)).data.members;

      allow read, update: if request.auth != null &&
        get(/databases/$(database)/documents/vaults/$(resource.data.vaultId)).data != null &&
        request.auth.uid in
        get(/databases/$(database)/documents/vaults/$(resource.data.vaultId)).data.members;
    }


  }
}
