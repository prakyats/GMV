rules_version = '2';
service cloud.firestore {
match /databases/{database}/documents {
// -------------------------
// USERS
// -------------------------
match /users/{userId} {
  allow read, write: if request.auth != null
    && request.auth.uid == userId;
}

  // -------------------------
  // VAULTS
  // -------------------------
  match /vaults/{vaultId} {

    // SAFE MEMBERSHIP CHECK (CRASH-PROOF)
    function isMember(vId) {
      let vault = get(/databases/$(database)/documents/vaults/$(vId));
      return vault.data != null
        && request.auth != null
        && request.auth.uid in vault.data.members;
    }

    // -------------------------
    // CREATE VAULT (STRICT)
    // -------------------------
    allow create: if request.auth != null
      && request.resource.data.keys().hasAll([
        'name',
        'inviteCode',
        'members',
        'createdBy',
        'createdAt'
      ])
      && request.resource.data.keys().hasOnly([
        'name',
        'inviteCode',
        'members',
        'createdBy',
        'createdAt'
      ])
      && request.resource.data.createdBy == request.auth.uid
      && request.resource.data.members is list
      && request.resource.data.members.size() == 1
      && request.resource.data.members[0] == request.auth.uid
      && request.resource.data.name is string
      && request.resource.data.inviteCode is string
      && request.resource.data.createdAt != null;

    // -------------------------
    // READ & LIST (ENABLED FOR UNIQUE CHECK)
    // -------------------------
    allow list: if request.auth != null
      && request.query.limit <= 1;

    allow read: if request.auth != null
      && request.auth.uid in resource.data.members;

  // -------------------------
  // UPDATE VAULT
  // -------------------------
  allow update: if request.auth != null && (

    // SELF-JOIN ONLY (USER ADDS THEMSELVES)
    (
      request.resource.data.members.size() == resource.data.members.size() + 1
      && request.auth.uid in request.resource.data.members
      && !(request.auth.uid in resource.data.members)
    )

    ||

    // CREATOR CAN RENAME ONLY
    (
      request.auth.uid == resource.data.createdBy
      && request.resource.data.diff(resource.data)
          .affectedKeys().hasOnly(['name'])
    )

    ||

    // LEAVE VAULT (REMOVE SELF ONLY)
    /* 
       Enforces: 
       1. User must be a current member
       2. Only the 'members' list is changed
       3. List size decreases by exactly 1
       4. The current user is no longer in the list
    */
    (
      request.auth.uid in resource.data.members
      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
      && request.resource.data.members.size() == resource.data.members.size() - 1
      && !(request.auth.uid in request.resource.data.members)
    )
  );

  // -------------------------
  // DELETE VAULT
  // -------------------------
  allow delete: if request.auth != null && (
    // Creator can always delete
    request.auth.uid == resource.data.createdBy
    ||
    // Last member leaving can delete (Enables 'Leave Vault' cleanup)
    (
      request.auth.uid in resource.data.members
      && resource.data.members.size() == 1
    )
  );

  // -------------------------
  // MEMORIES
  // -------------------------
  match /memories/{memoryId} {

    // READ MEMORY
    allow read: if request.auth != null
      && isMember(vaultId);

    // CREATE MEMORY
    allow create: if request.auth != null
      && isMember(vaultId)
      && request.resource.data.keys().hasOnly([
        'type',
        'text',
        'imageURL',
        'createdBy',
        'createdAt',
        'memoryDate',
        'viewedBy'
      ])
      && request.resource.data.type in ['text', 'image']
      && request.resource.data.createdBy == request.auth.uid
      && request.resource.data.createdAt != null
      && request.resource.data.memoryDate != null
      && (
        (
          request.resource.data.type == 'text'
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.imageURL == null
        )
        ||
        (
          request.resource.data.type == 'image'
          && request.resource.data.imageURL is string
          && request.resource.data.text is string
        )
      );

    // UPDATE MEMORY (REACTIONS & VIEWS)
    /*
       Enforces:
       1. Only vault members can update
       2. Only 'reactions' or 'viewedBy' fields can be modified
       3. Users can only add themselves to 'viewedBy' (strictly one at a time)
       4. Safely handles legacy docs where 'viewedBy' might be missing
    */
    allow update: if request.auth != null
      && isMember(vaultId)
      && (
        // reactions update
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
        ||
        // viewedBy update (SAFE + STRICT SELF ONLY)
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewedBy'])
          && request.auth.uid in request.resource.data.viewedBy
          && (
            !('viewedBy' in resource.data)
            ||
            request.resource.data.viewedBy.size() == resource.data.viewedBy.size() + 1
          )
        )
      );

    // DELETE DISABLED
    allow delete: if false;
  }
}

}
}
